# LLM and Embeddings
ANTHROPIC_API_KEY=           # Claude API for generation and verification
OPENAI_API_KEY=              # OpenAI embeddings (text-embedding-3-small)

# Database
SUPABASE_URL=                # Supabase project URL
SUPABASE_KEY=                # Supabase anon key
SUPABASE_SERVICE_KEY=        # Supabase service role key (for admin operations)

# Knowledge Graph
NEO4J_URI=                   # Neo4j AuraDB connection URI
NEO4J_USER=                  # Neo4j username
NEO4J_PASSWORD=              # Neo4j password

# Reranker (required — used to re-score hybrid retrieval candidates)
COHERE_API_KEY=              # Cohere Rerank API key (free tier at https://dashboard.cohere.com/api-keys)

# Optional overrides
EMBEDDING_MODEL=text-embedding-3-small  # Override embedding model
LLM_MODEL=claude-sonnet-4-20250514       # Override LLM model
RERANKER_MODEL=rerank-english-v3.0       # Override reranker (Cohere model ID)
